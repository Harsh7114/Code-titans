AVG_HOUSEHOLD_SIZE=
WATER_PER_PERSON_LITERS=
MEDICAL_KITS_PER_10_PEOPLE=

# ---------------------------------------------------------------------------
# Local xBD dataset (optional — leave blank if using Roboflow API instead)
# Download from: https://xview2.org/download
# ---------------------------------------------------------------------------
XBD_DATASET_ROOT=
XBD_WORKING_SPLIT=tier3
XBD_IMAGE_STAGE=post_disaster
XBD_MAX_RECORDS=100

# ---------------------------------------------------------------------------
# Roboflow — xView2-xBD model (Path A: API-only, no local dataset needed)
#
# Steps:
#   1. Sign up at https://roboflow.com and copy your API key from
#      https://app.roboflow.com/settings/api
#   2. The pre-trained xView2-xBD model lives at:
#      https://universe.roboflow.com/flow-wnra9/xview2-xbd
#      Set ROBOFLOW_MODEL_VERSION to the version number you want (e.g. 1).
#   3. In the app sidebar choose "Upload Image", upload any post-disaster
#      satellite PNG — the Roboflow API returns building damage bboxes and
#      the pipeline classifies them as no-damage / minor-damage /
#      major-damage / destroyed automatically.
# ---------------------------------------------------------------------------
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=xview2-xbd
ROBOFLOW_MODEL_VERSION=1
ROBOFLOW_CONFIDENCE=40
ROBOFLOW_OVERLAP=30

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEOCODING_PROVIDER=
GEOCODING_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
